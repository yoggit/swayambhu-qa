# swayambhu-qa — Environment Variables
# Copy this file to .env and fill in only the tools your team uses
# .env is gitignored — never commit real credentials

# ─── File source (no credentials needed) ─────────────────────────────────────
# Usage: /qa-pipeline --id ./story.md --tool playwright
# Omit --source entirely — swayambhu-qa reads the file directly.
#
# Native:   .md  .txt  .text
# Optional: .docx (npm install mammoth)
#           .doc  (npm install word-extractor)
#           .pdf  (npm install pdf-parse@1.1.1)

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Already handled by gh CLI auth (gh auth login) — no extra vars needed
# GITHUB_TOKEN=ghp_your_token_here   # Optional: only if not using gh CLI

# ─── JIRA / Atlassian ─────────────────────────────────────────────────────────
# Usage: --source jira
# Get your API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=QA          # Project key where bugs will be created (e.g. QA, PROJ)

# ─── Azure DevOps ─────────────────────────────────────────────────────────────
# Usage: --source ado
# Create PAT: dev.azure.com → User Settings → Personal Access Tokens
# Required scope: Work Items (Read & Write), Test Plans (Read & Write)
ADO_ORG=yourorganization
ADO_PROJECT=YourProjectName
ADO_PAT=your_ado_personal_access_token_here

# ─── Linear ───────────────────────────────────────────────────────────────────
# Usage: --source linear
# Create API key: linear.app → Settings → API → Personal API keys
LINEAR_API_KEY=lin_api_your_key_here
LINEAR_TEAM_ID=your_team_uuid_here        # Settings → Members → team URL ID
# LINEAR_BUG_LABEL_ID=uuid_of_bug_label   # Optional: auto-tag bugs with "Bug" label

# ─── Xray (JIRA plugin — Test Management) ─────────────────────────────────────
# Usage: --test-mgmt xray
# Get API keys: JIRA → Apps → Xray → API Keys
# Xray Cloud docs: https://docs.getxray.app/display/XRAYCLOUD/Global+Settings%3A+API+Keys
XRAY_CLIENT_ID=your_xray_client_id_here
XRAY_CLIENT_SECRET=your_xray_client_secret_here
XRAY_PROJECT_KEY=QA          # Same JIRA project key where your Xray tests live

# ─── TestRail (Test Management) ───────────────────────────────────────────────
# Usage: --test-mgmt testRail
# Get API key: TestRail → My Settings → API Keys
TESTRAIL_URL=https://yourcompany.testrail.io
TESTRAIL_USER=your.email@company.com
TESTRAIL_API_KEY=your_testrail_api_key_here
TESTRAIL_PROJECT_ID=1        # Integer project ID (visible in TestRail URL)

# ─── Zephyr Scale (JIRA plugin — Test Management) ─────────────────────────────
# Usage: --test-mgmt zephyr
# Get API token: JIRA → Zephyr Scale → API Tokens
ZEPHYR_BASE_URL=https://yourcompany.atlassian.net
ZEPHYR_API_TOKEN=your_zephyr_api_token_here
ZEPHYR_PROJECT_KEY=QA        # JIRA project key where Zephyr tests live

# ─── App URLs ─────────────────────────────────────────────────────────────────
# BASE_URL=http://localhost:3000      # Override default baseURL for UI tests
# API_BASE_URL=http://localhost:3000  # Override default for REST Assured / API tests

# ─── Appium (Mobile) ──────────────────────────────────────────────────────────
# APPIUM_URL=http://localhost:4723/wd/hub
# ANDROID_VERSION=12
# ANDROID_DEVICE=emulator-5554
# APP_PATH=/path/to/your/app.apk
# APP_PACKAGE=com.example.yourapp
# APP_ACTIVITY=.MainActivity
# IOS_VERSION=16.0
# IOS_DEVICE=iPhone 14
# IOS_APP_PATH=/path/to/your/app.ipa
# IOS_BUNDLE_ID=com.example.yourapp
